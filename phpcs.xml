<?xml version="1.0"?>
<ruleset name="wc-cic-pay">
	<description>WordPress Coding Standards pour wc-cic-pay</description>

	<file>includes</file>
	<file>wc-cic-pay.php</file>

	<arg value="sp"/>
	<arg name="basepath" value="."/>
	<arg name="extensions" value="php"/>
	<arg name="parallel" value="8"/>

	<rule ref="WordPress">
		<exclude name="WordPress.Files.FileName.InvalidClassFileName"/>
	</rule>

	<rule ref="WordPress.WP.I18n">
		<properties>
			<property name="text_domain" type="array">
				<element value="wc-cic-pay"/>
			</property>
		</properties>
	</rule>

	<rule ref="WordPress.WP.GlobalVariablesOverride"/>
</ruleset>
